# Порт (Render задаёт PORT сам; локально — по умолчанию 3000)
PORT=3000

# Мультитенант-конфиг: JSON { "<siteId>": { apiKey, botToken, backendUrl?, webhookSecret? } }
# apiKey       — секрет сайта для авторизации на релее (Bearer). Сгенерировать: openssl rand -hex 24
# botToken     — токен бота Telegram (@BotFather)
# backendUrl   — куда форвардить входящие webhook-апдейты (эндпоинт бота на сайте)
# webhookSecret— секрет-токен Telegram (setWebhook secret_token); валидируется на входящих
# В бою задаётся в дашборде Render (Environment), НЕ в git.
RELAY_SITES={"117fstec":{"apiKey":"k_live_CHANGE_ME","botToken":"123456:CHANGE_ME","backendUrl":"https://117fstec.credos.ru/api/bot","webhookSecret":"whs_CHANGE_ME"}}

# Тюнинг (опц.)
REQ_TIMEOUT_MS=15000
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=10000

# Корень Bot API (опц.) — переопределяется в тестах, в бою не трогать
# TG_API_ROOT=https://api.telegram.org

# --- для MCP (локально) ---
# RELAY_URL=https://telegram-bot-relay.onrender.com
# RELAY_API_KEY=k_live_CHANGE_ME

# --- Render (только локально, для CLI/API; НЕ коммитить) ---
# Полный доступ к аккаунту Render, включая чтение env с botToken. При утечке — отозвать ключ.
# RENDER_API_KEY=rnd_CHANGE_ME
# RENDER_SERVICE_ID=srv-d97tpketrd3s739o7kqg
